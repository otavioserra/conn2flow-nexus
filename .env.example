# =============================================================================
# Conn2Flow Nexus AI - Environment Variables
# Copy this file to .env and fill in the values
# =============================================================================

# --- Application ---
APP_NAME=conn2flow-nexus-ai
APP_ENV=development
APP_DEBUG=true
APP_VERSION=0.1.0
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# --- API Security ---
C2F_API_KEY=your-c2f-api-key-here

# --- LLM Provider Keys ---
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
GEMINI_API_KEY=your-gemini-key-here
GROQ_API_KEY=gsk_your-groq-key-here

# --- Default LLM ---
DEFAULT_MODEL=gpt-4o-mini

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_INCOMING=c2f_incoming_tasks
KAFKA_TOPIC_COMPLETED=c2f_completed_tasks
KAFKA_CONSUMER_GROUP=c2f-workers

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Webhook (Conn2Flow Callback) ---
C2F_WEBHOOK_URL=https://your-conn2flow-instance.com/api/webhook/ai-response
C2F_WEBHOOK_SECRET=your-webhook-signing-secret-here
